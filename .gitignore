# OS
.DS_Store
# build artifacts
/dist/
# test
coverage.out
# paintress runtime state — ignore contents individually (insights/ is git-tracked per S0030)
.expedition/.run/
.expedition/events/
.expedition/inbox/
.expedition/outbox/
.expedition/archive/
.expedition/journal/
.expedition/skills/
.expedition/config.yaml
.expedition/.otel.env
.expedition/.gitignore
# nested .expedition/ dirs from test/dev runs (state dirs created outside repo root)
internal/**/.expedition/
# environment-specific local files (must not contain full paths)
*.local.*
# claude local settings
.claude/*.local.*
# git worktrees
.worktrees/
# plan drafts (ephemeral)
docs/plans/
# golang
.gocache/
# firebase local debug log
firebase-debug.log
